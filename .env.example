# ============================================================
# EBM AI App — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ============================================================

# Rails
SECRET_KEY_BASE=run_rails_secret_to_generate_this
RAILS_ENV=development
RAILS_LOG_TO_STDOUT=true

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/ebmpro_development

# App host (used in emails)
APP_HOST=your-app.onrender.com

# AWS (for S3 autonomous pipeline)
AWS_ACCESS_KEY_ID=your_new_aws_access_key
AWS_SECRET_ACCESS_KEY=your_new_aws_secret_key
AWS_REGION=us-west-2
AWS_S3_BUCKET=ebmpros-ftp

# Email — SMTP (use AWS SES or any provider)
# For AWS SES: create SMTP credentials in AWS Console → SES → SMTP Settings
# Note: SES SMTP credentials are different from your IAM access keys
SMTP_HOST=email-smtp.us-west-2.amazonaws.com
SMTP_PORT=587
SMTP_DOMAIN=ebmpros.com
SMTP_USERNAME=your_ses_smtp_username
SMTP_PASSWORD=your_ses_smtp_password

# Frontend URL (for CORS — set to your Lovable app URL in production)
FRONTEND_URL=http://localhost:3001

# JWT Secret (for API authentication)
JWT_SECRET_KEY=run_rails_secret_to_generate_this
