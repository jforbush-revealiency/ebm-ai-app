/** 
 * A service for changing the password 
 * 
 * Type: Service
 * 
 * ID: changePasswordService
 * 
 */
//= depend_on_asset 'secure/app/components/changePassword/changePassword.html'
(function () {
    'use strict';

    angular.module('changePassword').factory('changePasswordService',
        [
            '$uibModal',
            'clientRootPath',
            function ($uibModal, clientRootPath) {

                //----------------------------------------------
                // openDialog
                //----------------------------------------------
                function openDialog(requirePasswordChange) {
                  return $uibModal.open({
                      templateUrl: '<%= asset_path("secure/app/components/changePassword/changePassword.html") %>',
                      templateUrl: clientRootPath + '/components/changePassword/changePassword.html',
                      controller: 'changePasswordController',
                      size: 'md',
                      backdrop: 'static',
                      resolve: {
                          requirePasswordChange: function () {
                              return requirePasswordChange;
                          }
                      }
                  });
                }

                return {
                    openDialog: openDialog
                };
            }
        ]);
})();
